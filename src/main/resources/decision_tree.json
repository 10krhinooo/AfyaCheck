{
  "node_id": "root",
  "question_key": "consent",
  "children": [
    {
      "condition": "consent == 'no'",
      "action": "end",
      "message": "Thank you. You have declined to participate."
    },
    {
      "condition": "consent == 'yes'",
      "action": "goto",
      "next": "age_check"
    }
  ],
  "subtrees": {
    "age_check": {
      "node_id": "age_check",
      "question_key": "age",
      "children": [
        {
          "condition": "age < 13 || age == null",
          "action": "end",
          "message": "This assessment is designed for people aged 13 and older."
        },
        {
          "condition": "age >= 13",
          "action": "goto",
          "next": "gender_node"
        }
      ]
    },
    "gender_node": {
      "node_id": "gender_node",
      "question_key": "gender",
      "children": [
        {
          "condition": "gender != null",
          "action": "goto",
          "next": "sexual_activity_node"
        }
      ]
    },
    "sexual_activity_node": {
      "node_id": "sexual_activity_node",
      "question_key": "sexual_activity",
      "children": [
        {
          "condition": "sexual_activity == 'no' || sexual_activity == null",
          "action": "goto",
          "next": "non_sexually_active_node"
        },
        {
          "condition": "sexual_activity == 'yes'",
          "action": "goto",
          "next": "sexual_active_node"
        }
      ]
    },
    "non_sexually_active_node": {
      "node_id": "non_sexually_active_node",
      "children": [
