          "next": "female_non_active_node"
        }
      ]
    },
    "female_non_active_node": {
      "node_id": "female_non_active_node",
      "children": [
        {
          "condition": "gender == 'Female'",
          "action": "goto",
          "next": "pregnancy_status_non_active"
        },
        {
          "condition": "gender != 'Female'",
          "action": "goto",
          "next": "knowledge_assessment_node"
        }
      ]
    },
    "pregnancy_status_non_active": {
      "node_id": "pregnancy_status_non_active",
      "question_key": "pregnancy_status",
      "children": [
        {
          "condition": "pregnancy_status == 'yes'",
          "action": "goto",
          "next": "pregnancy_related_care"
        },
