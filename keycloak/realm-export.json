{
  "realm": "afyacheck",
  "enabled": true,
  "displayName": "AfyaCheck",
  "loginTheme": "afyacheck",
  "accountTheme": "afyacheck",
  "emailTheme": "afyacheck",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "resetPasswordAllowed": true,
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1)",
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",
  "smtpServer": {
    "host": "smtp.gmail.com",
    "port": "587",
    "from": "${MAIL_USERNAME}",
    "fromDisplayName": "AfyaCheck",
    "auth": "true",
    "user": "${MAIL_USERNAME}",
    "password": "${MAIL_PASSWORD}",
    "starttls": "true",
    "ssl": "false"
  },
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Regular AfyaCheck user"
      },
      {
        "name": "ADMIN",
        "description": "AfyaCheck staff — access to the admin console"
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-afyacheck",
    "composite": true,
    "composites": {
      "realm": ["USER"]
    }
  },
  "clients": [
    {
      "clientId": "afyacheck-spa",
      "name": "AfyaCheck SPA",
      "description": "Public client used by the React frontend (Authorization Code + PKCE, no client secret).",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/app/*",
        "http://localhost:8080/app/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/##http://localhost:8080/"
      }
    },
    {
      "clientId": "afyacheck-backend",
      "name": "AfyaCheck Backend (service account)",
      "description": "Confidential client used only by the Spring Boot backend's KeycloakAdminService to assign/remove realm roles when an admin changes a user's role via the admin console. Never used for a user-facing login flow — no standard/implicit flow, no redirect URIs.",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_BACKEND_CLIENT_SECRET}",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": true
    }
  ],
  "users": [
    {
      "username": "admin@afyacheck.com",
      "email": "admin@afyacheck.com",
      "firstName": "AfyaCheck",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${SEED_ADMIN_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-afyacheck", "ADMIN"]
    },
    {
      "username": "service-account-afyacheck-backend",
      "enabled": true,
      "serviceAccountClientId": "afyacheck-backend",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users", "view-realm"]
      }
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": false,
      "trustEmail": true,
      "storeToken": false,
      "config": {
        "clientId": "${GOOGLE_OAUTH_CLIENT_ID}",
        "clientSecret": "${GOOGLE_OAUTH_CLIENT_SECRET}",
        "defaultScope": "openid profile email"
      }
    },
    {
      "alias": "github",
      "providerId": "github",
      "enabled": false,
      "trustEmail": true,
      "storeToken": false,
      "config": {
        "clientId": "${GITHUB_OAUTH_CLIENT_ID}",
        "clientSecret": "${GITHUB_OAUTH_CLIENT_SECRET}"
      }
    }
  ]
}
